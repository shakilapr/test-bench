# Copy to .env and fill in. Do not commit .env.
# Backend
NODE_ENV=development
PORT=3000
SQLITE_PATH=./data/bench.sqlite

# MQTT (Mosquitto)
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# InfluxDB v2
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=dev-token
INFLUX_ORG=bench
INFLUX_BUCKET=bench

# Grafana (used by backend to construct embed URLs)
GRAFANA_URL=http://localhost:3001
